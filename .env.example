# PostgreSQL (локально: Docker, Neon, Supabase, …)
# Быстрый локальный старт с Docker: npm run bootstrap (Postgres на порту 5433)
# Пример Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Для Prisma migrate на Neon: обычно тот же URL, что и DATABASE_URL (или отдельный «direct» без pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Опционально: выгрузка env на Vercel (scripts/push-env-to-vercel.mjs, push-vercel-env.cmd)
# VERCEL_TOKEN=""
# VERCEL_PROJECT_NAME="testivor"
# VERCEL_PRODUCTION_URL="https://ваш-проект.vercel.app"

# Публичный URL сайта (на проде — https://ваш-проект.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# LLM: OpenAI-совместимый API. Достаточно ОДНОГО ключа (имя на выбор):
# OPENAI_API_KEY — основной вариант (OpenAI или тот же токен при кастомном OPENAI_BASE_URL)
# LLM_API_KEY / AI_API_KEY — то же самое, если привычнее так назвать переменную
# OPENROUTER_API_KEY — ключ OpenRouter; если задан без OPENAI_API_KEY, base URL подставится сам
OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_MODEL="openai/gpt-4o-mini"
# Рекомендация: openai/gpt-4o-mini — дёшево, хороший русский и режим JSON для планов/сводок.
# На прямом OpenAI модель по умолчанию gpt-4o-mini; на OpenRouter — openai/gpt-4o-mini (префикс провайдера обязателен).
OPENAI_BASE_URL=""
OPENAI_MODEL=""
# OPENROUTER_HTTP_REFERER="https://your-site.vercel.app"
# OPENROUTER_APP_TITLE="Interview Intelligence Platform"
# OPENAI_TIMEOUT_MS=120000
# Если провайдер (например часть маршрутов OpenRouter) падает с 400 на JSON mode — true отключает response_format json_object (промпт по-прежнему просит JSON).
# OPENAI_DISABLE_JSON_MODE=true
