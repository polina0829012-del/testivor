generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Миграции Prisma; на Neon часто = тот же URL, что и DATABASE_URL (или «direct», без pooler).
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  vacancies    Vacancy[]
  /// Вопросы, внесённые в общий банк для коллег
  sharedBankQuestions QuestionBankTemplateQuestion[]
}

model Vacancy {
  id                       String      @id @default(cuid())
  userId                   String
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                    String
  level                    String
  competencies             String
  /// Устарело: текст перенесён в competencies; поле очищается при сохранении из UI
  expectationsForCandidate String    @default("")
  /// Внутренняя заметка только для HR
  recruiterInternalNote    String      @default("")
  /// low | normal | high | urgent
  priority                 String      @default("normal")
  /// draft | active | on_hold | closed
  status                   String      @default("active")
  targetCloseDate          DateTime?
  /// office | hybrid | remote | ""
  workFormat               String      @default("")
  planUpdatedAt            DateTime    @default(now())
  createdAt                DateTime    @default(now())
  /// Кандидат, зафиксированный при закрытии вакансии (трудоустройство)
  hiredCandidateId         String?     @unique
  hiredCandidate           Candidate?  @relation("VacancyHiredCandidate", fields: [hiredCandidateId], references: [id], onDelete: SetNull)
  blocks                   PlanBlock[]
  candidates               Candidate[]
}

model PlanBlock {
  id        String         @id @default(cuid())
  vacancyId String
  vacancy   Vacancy        @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int
  required  Boolean        @default(false)
  questions PlanQuestion[]
  scores    BlockScore[]
}

model PlanQuestion {
  id           String           @id @default(cuid())
  blockId      String
  block        PlanBlock        @relation(fields: [blockId], references: [id], onDelete: Cascade)
  text         String
  sortOrder    Int
  /// text = развёрнутый ответ; rating = балл 1–5 по пункту
  responseType String           @default("text")
  answers      QuestionAnswer[]
}

model Candidate {
  id                 String         @id @default(cuid())
  vacancyId          String
  vacancy            Vacancy        @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  hiredOnVacancy     Vacancy?       @relation("VacancyHiredCandidate")
  name               String
  summaryJson        String?
  risksJson          String?
  discrepanciesJson  String?
  summaryUpdatedAt   DateTime?
  createdAt          DateTime       @default(now())
  interviewers       Interviewer[]
}

model Interviewer {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String
  inviteToken String    @unique @default(cuid())
  protocol    Protocol?
}

model Protocol {
  id              String            @id @default(cuid())
  interviewerId   String            @unique
  interviewer     Interviewer       @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  submittedAt     DateTime?
  scores          BlockScore[]
  questionAnswers QuestionAnswer[]
}

model QuestionAnswer {
  id             String       @id @default(cuid())
  protocolId     String
  protocol       Protocol     @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  planQuestionId String
  planQuestion   PlanQuestion @relation(fields: [planQuestionId], references: [id], onDelete: Cascade)
  textAnswer     String       @default("")
  scoreAnswer    Int?

  @@unique([protocolId, planQuestionId])
}

model BlockScore {
  id          String    @id @default(cuid())
  protocolId  String
  protocol    Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  planBlockId String
  planBlock   PlanBlock @relation(fields: [planBlockId], references: [id], onDelete: Cascade)
  /// Итоговая оценка блока от интервьюера (1–5); для расхождений между интервьюерами и для ИИ
  overallScore Int
  /// Среднее по балльным пунктам плана в блоке (округление 1–5); при отсутствии балльных вопросов — 3
  score        Int
  notes        String @default("")

  @@unique([protocolId, planBlockId])
}

/// Направление собеседования (фильтр в банке вопросов)
model QuestionBankDirection {
  id        String                    @id @default(cuid())
  slug      String                    @unique
  label     String
  sortOrder Int                       @default(0)
  blocks    QuestionBankTemplateBlock[]
}

/// Блок внутри направления (встроенный или созданный из вкладов коллег)
model QuestionBankTemplateBlock {
  id          String   @id @default(cuid())
  directionId String
  direction   QuestionBankDirection @relation(fields: [directionId], references: [id], onDelete: Cascade)
  /// Для встроенных блоков (intro, hard-skills, …) — стабильный ключ; у блоков от HR — null
  sourceKey   String?
  title       String
  required    Boolean  @default(false)
  sortOrder   Int      @default(0)
  questions   QuestionBankTemplateQuestion[]

  @@unique([directionId, sourceKey])
  @@index([directionId])
}

model QuestionBankTemplateQuestion {
  id                  String   @id @default(cuid())
  blockId             String
  block               QuestionBankTemplateBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  text                String
  sortOrder           Int      @default(0)
  /// text | rating — как в PlanQuestion
  responseType        String   @default("text")
  contributedByUserId String?
  contributedBy       User?    @relation(fields: [contributedByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())

  @@index([blockId])
}
